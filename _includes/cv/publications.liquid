{% comment %}
  Numbered academic publication list for both RenderCV and JSONResume formats.
{% endcomment %}

<ol class="cv-publications">
  {% for entry in entries %}
    <li class="cv-publication">
      <span class="cv-publication__number" aria-hidden="true">{{ forloop.index }}</span>
      <div class="cv-publication__body">
        {% assign publication_title = entry.title | default: entry.name %}
        {% if entry.url %}
          <h4 class="cv-publication__title">
            <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">{{ publication_title }}</a>
          </h4>
        {% else %}
          <h4 class="cv-publication__title">{{ publication_title }}</h4>
        {% endif %}

        {% if entry.authors %}
          <p class="cv-publication__authors">{{ entry.authors | join: ', ' }}</p>
        {% endif %}

        <p class="cv-publication__meta">
          {% if entry.journal -%}
            <em>{{ entry.journal }}</em>
          {%- elsif entry.publisher -%}
            <em>{{ entry.publisher }}</em>
          {%- endif %}
          {% if entry.journal or entry.publisher %}
            <span aria-hidden="true"> · </span>
          {% endif %}
          {% if entry.releaseDate %}{{ entry.releaseDate | split: '-' | first }}{% elsif entry.date %}{{ entry.date | split: '-' | first }}{% endif %}
        </p>
      </div>
    </li>
  {% endfor %}
</ol>
