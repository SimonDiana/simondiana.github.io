{% comment %} Compact academic education entries with institution marks. {% endcomment %}

<ul class="cv-education">
  {% for entry in entries %}
    {% capture study_type %}{% if entry.degree %}{{ entry.degree }}{% elsif entry.studyType %}{{ entry.studyType }}{% endif %}{% endcapture %}
    {% capture start_date %}{% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}{% endcapture %}
    {% capture end_date %}{% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}{% endcapture %}
    {% capture education_date %}
      {% if entry.date %}
        {{ entry.date }}
      {% elsif start_date != '' %}
        {{ start_date | split: '-' | first }}–{{ end_date | split: '-' | first | default: 'Present' }}
      {% endif %}
    {% endcapture %}

    {% assign logo_path = null %}
    {% if entry.institution == 'Westlake University' %}
      {% assign logo_path = '/assets/img/university-logos/westlake-university-logo.png' %}
    {% elsif entry.institution == 'Soochow University' %}
      {% assign logo_path = '/assets/img/university-logos/soochow-university-logo.jpg' %}
    {% endif %}

    <li class="cv-education__entry">
      {% if logo_path %}
        <div class="cv-education__mark">
          <img src="{{ logo_path | relative_url }}" alt="{{ entry.institution }} emblem" loading="lazy">
        </div>
      {% endif %}

      <div class="cv-education__body">
        <div class="cv-education__heading">
          <div>
            <h4 class="cv-education__degree">
              {{ study_type | strip -}}
              {%- if entry.area %} in {{ entry.area }}{% endif %}
            </h4>
            {% if entry.institution %}
              <p class="cv-education__institution">{{ entry.institution }}</p>
            {% endif %}
          </div>
          {% if education_date != '' -%}
            <span class="cv-education__date">{{ education_date | strip }}</span>
          {%- endif %}
        </div>

        {% if entry.location %}
          <p class="cv-education__location"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{ entry.location }}</p>
        {% endif %}

        {% if entry.courses or entry.highlights %}
          <ul class="cv-education__highlights">
            {% for item in entry.courses %}
              <li>{{ item }}</li>
            {% endfor %}
            {% for item in entry.highlights %}
              <li>{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </li>
  {% endfor %}
</ul>
